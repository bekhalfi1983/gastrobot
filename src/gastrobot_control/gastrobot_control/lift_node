#!/usr/bin/env python3

import rclpy
from rclpy.node import Node
from std_msgs.msg import String
import serial
import time


class LiftNode(Node):

    def __init__(self):
        super().__init__('lift_node')

        self.get_logger().info("=== LIFT NODE RUNNING ===")

        # ================= PARAMETERS =================
        self.declare_parameter(
            "port",
            "/dev/serial/by-id/usb-Arduino__www.arduino.cc__0043_9503230373735171A2E1-if00"
        )
        self.declare_parameter("baud", 115200)

        self.port = self.get_parameter("port").value
        self.baud = int(self.get_parameter("baud").value)

        self.ser = None
        self.connect_serial()

        # ================= ROS =================
        self.create_subscription(
            String,
            "/lift_cmd",
            self.cmd_callback,
            10
        )

        self.status_pub = self.create_publisher(
            String,
            "/lift_status",
            10
        )

        # Timer (20 Hz read)
        self.timer = self.create_timer(0.05, self.read_serial)

        self.last_debug_time = time.monotonic()

        self.get_logger().info("Lift Node Started")

    # ================= SERIAL =================
    def connect_serial(self):
        while True:
            try:
                self.ser = serial.Serial(self.port, self.baud, timeout=0.1)
                time.sleep(2)  # Arduino reset delay

                self.get_logger().info(f"Connected to Arduino on {self.port}")
                break

            except Exception as e:
                self.get_logger().error(f"Serial connect failed: {e}")
                time.sleep(2)

    # ================= SEND =================
    def cmd_callback(self, msg):
        if self.ser is None or not self.ser.is_open:
            return

        try:
            cmd = msg.data.strip()
            self.ser.write((cmd + '\n').encode())

            self.get_logger().info(f"Sent lift cmd: {cmd}")

        except Exception as e:
            self.get_logger().error(f"Write failed: {e}")
            self.reconnect()

    # ================= READ =================
    def read_serial(self):
        if self.ser is None or not self.ser.is_open:
            return

        try:
            if self.ser.in_waiting:
                line = self.ser.readline().decode(errors="ignore").strip()

                if line:
                    msg = String()
                    msg.data = line
                    self.status_pub.publish(msg)

            # Debug (1 Hz)
            now = time.monotonic()
            if now - self.last_debug_time > 1.0:
                self.get_logger().info("Lift node alive")
                self.last_debug_time = now

        except Exception as e:
            self.get_logger().error(f"Read failed: {e}")
            self.reconnect()

    # ================= RECONNECT =================
    def reconnect(self):
        try:
            if self.ser:
                self.ser.close()
        except:
            pass

        self.get_logger().warn("Reconnecting Arduino...")
        self.connect_serial()

    # ================= CLEANUP =================
    def destroy_node(self):
        try:
            if self.ser:
                self.ser.close()
        except:
            pass

        super().destroy_node()


def main(args=None):
    rclpy.init(args=args)

    node = LiftNode()

    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
